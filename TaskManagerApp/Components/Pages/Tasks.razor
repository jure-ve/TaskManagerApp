@page "/tasks"
@attribute [Authorize]
@using TaskManagerApp.Shared.Models
@using TaskManagerApp.Shared.Services
@inject ITaskService TaskService
@rendermode InteractiveServer

<PageTitle>Gestión de Tareas</PageTitle>

<h1>Gestión de Tareas <span class="badge-service">@TaskService.GetType().Name</span></h1>
<p>Esta página corre en el servidor y se comunica con el navegador mediante SignalR.</p>

<div class="alert alert-info d-flex align-items-center">
    <div>
        <strong>Entorno:</strong> @RendererInfo.Name <br />
        <strong>Interactivo:</strong> @(RendererInfo.IsInteractive ? "Sí" : "No (Prerendering)") <br />
        <small>El servicio inyectado es <code>@TaskService.GetType().Name</code>, lo que significa que estamos accediendo a datos en <b>Memoria/BD</b> directamente, sin llamadas HTTP.</small>
    </div>
</div>

<div class="mb-3">
    <input @bind="newTaskTitle" @bind:event="oninput" @onkeyup="HandleKeyUp" placeholder="Nueva tarea..." class="form-control" />
    <button @onclick="AddTask" class="btn btn-primary mt-2">Agregar</button>
</div>

@if (tasks == null)
{
    <p><em>Cargando...</em></p>
}
else
{
    <ul class="list-group">
        @foreach (var task in tasks)
        {
            <li class="list-group-item d-flex justify-content-between align-items-center">
                <span style="text-decoration: @(task.IsCompleted ? "line-through" : "none")">@task.Title</span>
                <button @onclick="() => ToggleTask(task.Id)" class="btn btn-sm @(task.IsCompleted ? "btn-warning" : "btn-success")">
                    @(task.IsCompleted ? "Desmarcar" : "Completar")
                </button>
            </li>
        }
    </ul>
}

@code {
    private List<TaskItem>? tasks;
    private string newTaskTitle = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        // En InteractiveServer, el estado se mantiene en memoria en el servidor para esta conexión SignalR.
        // Ojo: Si el usuario recarga la página, esta instancia del componente se destruye y el estado se pierde.
        tasks = await TaskService.GetTasksAsync();
    }

    private async Task AddTask()
    {
        if (!string.IsNullOrWhiteSpace(newTaskTitle))
        {
            await TaskService.AddTaskAsync(newTaskTitle);
            newTaskTitle = string.Empty;
            tasks = await TaskService.GetTasksAsync();
        }
    }

    private async Task HandleKeyUp(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            await AddTask();
        }
    }

    private async Task ToggleTask(Guid id)
    {
        await TaskService.ToggleTaskAsync(id);
        tasks = await TaskService.GetTasksAsync();
    }
}
