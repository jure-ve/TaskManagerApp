@page "/analytics"
@attribute [Authorize]
@using TaskManagerApp.Shared.Models
@using TaskManagerApp.Shared.Services
@inject ITaskService TaskService
@inject PersistentComponentState ApplicationState
@implements IDisposable
@rendermode InteractiveAuto

<PageTitle>Analíticas</PageTitle>

<h1>Analíticas <span class="badge-service">@TaskService.GetType().Name</span></h1>
<p>Esta página corre en modo Auto. En SSR será <code>ServerTaskService</code> y en el cliente será <code>ClientTaskService</code>.</p>

<div class="alert alert-info d-flex align-items-center">
    <div>
        <strong>Entorno:</strong> @RendererInfo.Name <br />
        <strong>Interactivo:</strong> @(RendererInfo.IsInteractive ? "Sí" : "No (Prerendering)") <br />
        <small>Servicio inyectado: <code>@TaskService.GetType().Name</code>. Si es ClientTaskService, los datos se piden por HTTP.</small>
    </div>
</div>

@if (tasks == null)
{
    <p><em>Calculando métricas...</em></p>
}
else
{
    <div class="card">
        <div class="card-body">
            <h5 class="card-title">Resumen de Tareas</h5>
            <p class="card-text">Total de tareas: <strong>@tasks.Count</strong></p>
            <p class="card-text">Tareas completadas: <strong>@tasks.Count(t => t.IsCompleted)</strong></p>
            <p class="card-text">Tareas pendientes: <strong>@tasks.Count(t => !t.IsCompleted)</strong></p>
            
            @{ 
                var percentage = tasks.Count > 0 ? (int)((tasks.Count(t => t.IsCompleted) / (double)tasks.Count) * 100) : 0;
            }
            <div class="progress" style="height: 20px; margin-bottom: 20px;">
                <div class="progress-bar" role="progressbar" style="width: @percentage%;" aria-valuenow="@percentage" aria-valuemin="0" aria-valuemax="100">@percentage%</div>
            </div>
            
            <button class="btn btn-outline-primary mt-3" @onclick="RefreshData">Actualizar datos</button>
        </div>
    </div>
}

@code {
    private List<TaskItem>? tasks;
    private PersistingComponentStateSubscription persistingSubscription;

    protected override async Task OnInitializedAsync()
    {
        persistingSubscription = ApplicationState.RegisterOnPersisting(PersistData);

        if (!ApplicationState.TryTakeFromJson<List<TaskItem>>("tasks", out var restored))
        {
            await RefreshData();
        }
        else
        {
            tasks = restored;
        }
    }

    private async Task RefreshData()
    {
        tasks = await TaskService.GetTasksAsync();
    }

    private Task PersistData()
    {
        if (tasks != null)
        {
            ApplicationState.PersistAsJson("tasks", tasks);
        }
        return Task.CompletedTask;
    }

    public void Dispose()
    {
        persistingSubscription.Dispose();
    }
}
